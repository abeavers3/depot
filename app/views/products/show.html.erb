<div class="product-show">
  <div class="product-entry">
    <% if @product.image_url.present? %>
      <%= image_tag @product.image_url, class: "product-image" %>
    <% end %>

    <div>
      <div class="product-category-label">
        <%= @product.category&.name || "Uncategorized" %>
      </div>

      <h1><%= @product.title %></h1>

      <p>
        <%= sanitize(@product.description) %>
      </p>

      <p class="product-price">
        <%= number_to_currency(@product.price) %>
      </p>

      <div class="cart-page-actions">
        <%= link_to "Edit this product", edit_product_path(@product), class: "cart-back-link" %>
        <%= link_to "Back to products", products_path, class: "cart-back-link" %>

        <%= button_to "Destroy this product",
          @product,
          method: :delete,
          data: { turbo_confirm: "Are you sure?" },
          class: "cart-empty-button" %>
      </div>
    </div>
  </div>
</div>
